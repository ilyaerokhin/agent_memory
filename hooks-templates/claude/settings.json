{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "agent-memory sync-branch && agent-memory load"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "agent-memory save --transcript-path \"$CLAUDE_TRANSCRIPT_PATH\""
          }
        ]
      }
    ]
  }
}
